# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (required in production)
MONGO_URI=mongodb://127.0.0.1:27017/skillsphere

# Auth — use a long random string (required)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Admin seed (npm run seed) — set a strong password before seeding
ADMIN_EMAIL=admin@skillsphere.net
ADMIN_USERNAME=skillsphere_admin
ADMIN_PASSWORD=admin123
